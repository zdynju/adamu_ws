<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
    <xacro:macro name="adam_u_ros2_control" params="name initial_positions_file">
        <xacro:property name="initial_positions" value="${xacro.load_yaml(initial_positions_file)['initial_positions']}"/>

        <ros2_control name="${name}" type="system">
            <hardware>
                <plugin>mujoco_ros2_control/MujocoSystemInterface</plugin>
                <param name="mujoco_model">$(find adamu_description)/mujoco/scene_adam_u.xml</param>
                <param name="odom_free_joint_name">target_box_fixed_joint</param>
                <param name="odom_topic">/simulator/box_state</param>
            </hardware>
            
            <sensor name="overhead_cam">
              <param name="frame_name">overhead_cam_frame</param>
              <param name="info_topic">/overhead_cam/color/camera_info</param>
              <param name="image_topic">/overhead_cam/color/image_raw</param>
              <param name="depth_topic">/overhead_cam/aligned_depth_to_color/image_raw</param>
            </sensor>
            <sensor name="left_fts_sensor">
              <param name="mujoco_type">fts</param>
              <!-- There is no requirement for the mujoco_sensor_name to match the ros2_control sensor name -->
              <param name="mujoco_sensor_name">left_fts_sensor</param>
              <!-- Default value of force_mjcf_suffix is '_force' -->
              <param name="force_mjcf_suffix">_force</param>
              <!-- Default value of torque_mjcf_suffix is '_torque' -->
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>
            <sensor name="right_fts_sensor">
              <param name="mujoco_type">fts</param>
              <!-- There is no requirement for the mujoco_sensor_name to match the ros2_control sensor name -->
              <param name="mujoco_sensor_name">right_fts_sensor</param>
              <!-- Default value of force_mjcf_suffix is '_force' -->
              <param name="force_mjcf_suffix">_force</param>
              <!-- Default value of torque_mjcf_suffix is '_torque' -->
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>
            <sensor name="L_thumb_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">L_thumb_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="L_index_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">L_index_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="L_middle_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">L_middle_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="L_ring_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">L_ring_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="L_pinky_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">L_pinky_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="R_thumb_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">R_thumb_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="R_index_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">R_index_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="R_middle_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">R_middle_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="R_ring_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">R_ring_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>

            <sensor name="R_pinky_pad_sensor">
              <param name="mujoco_type">fts</param>
              <param name="mujoco_sensor_name">R_pinky_pad</param>
              <param name="force_mjcf_suffix">_force</param>
              <param name="torque_mjcf_suffix">_torque</param>
              <state_interface name="force.x"/>
              <state_interface name="force.y"/>
              <state_interface name="force.z"/>
              <state_interface name="torque.x"/>
              <state_interface name="torque.y"/>
              <state_interface name="torque.z"/>
            </sensor>
            <joint name="shoulderPitch_Left">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['shoulderPitch_Left']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="shoulderRoll_Left">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['shoulderRoll_Left']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="shoulderYaw_Left">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
