                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['elbow_Left']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="wristYaw_Left">
