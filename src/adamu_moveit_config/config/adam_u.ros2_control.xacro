                <state_interface name="velocity"/>
            </joint>
            <joint name="elbow_Right">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['elbow_Right']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="wristYaw_Right">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['wristYaw_Right']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="wristPitch_Right">
