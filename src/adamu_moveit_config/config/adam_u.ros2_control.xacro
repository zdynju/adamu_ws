                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="wristPitch_Left">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['wristPitch_Left']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="wristRoll_Left">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['wristRoll_Left']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="shoulderPitch_Right">
                <command_interface name="position"/>
                <command_interface name="velocity"/>
                <state_interface name="position">
                  <param name="initial_value">${initial_positions['shoulderPitch_Right']}</param>
                </state_interface>
                <state_interface name="velocity"/>
            </joint>
            <joint name="shoulderRoll_Right">
